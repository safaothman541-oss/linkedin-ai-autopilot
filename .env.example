# Copy to .env for LOCAL testing only. On GitHub these go in repo Secrets/Variables.
GEMINI_API_KEY=

# LinkedIn — get these by running:  node tools/get-linkedin-token.js <CLIENT_ID> <CLIENT_SECRET>
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
# Optional (auto-refresh): provide these to mint a fresh token each run
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Behaviour (optional)
POST_MODE=auto          # auto = publish to LinkedIn | approve = only send to Telegram | off
TTS_VOICE=af_heart      # run `npx hyperframes tts --list` to see voices
BRAND_HANDLE=           # e.g. "@yourname" shown at the bottom of the video
LINKEDIN_VERSION=202506 # bump if LinkedIn asks for a newer API version
